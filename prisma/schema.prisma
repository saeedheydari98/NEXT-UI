generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Conversion {
  id        Int      @id @default(autoincrement())
  date      String
  fromType  String
  toType    String
  result    String
  createdAt DateTime @default(now())
}