generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Conversion {
  id        Int      @id @default(autoincrement())
  date      String
  fromType  String
  toType    String
  result    String
  createdAt DateTime @default(now())
}